   "source": [
    "#####################\n",
    "# Inicio del Programa\n",
    "#####################\n",
    "\n",
    "if camera.isOpened():\n",
    "   cv2.namedWindow('chessBoard')\n",
    "   cont = 0\n",
    "   R1=np.eye(3);\n",
    "   T1=np.zeros((3,1))\n",
    "   cont = 0\n",
    "   changeFPS = False\n",
    "   while True:\n",
    "      etval, img = camera.read()\n",
    "      if etval == True:   \n",
    "         \n",
    "         #Encontrar esquinas global\n",
    "         #retval, Esquinas = cv2.findChessboardCorners(img, (8, 6))\n",
    "\n",
    "         ####################################################\n",
    "         # DETECCION DE ESQUINAS\n",
    "         ####################################################\n",
    "\n",
    "         if useROI:\n",
    "\n",
    "             xmin = max(0, xminROI)\n",
    "             ymin = max(0, yminROI)\n",
    "\n",
    "             xmax = min(gray.shape[1], xmaxROI)\n",
    "             ymax = min(gray.shape[0], ymaxROI)\n",
    "\n",
    "             grayROI = gray[ymin:ymax, xmin:xmax]\n",
    "\n",
    "             retval, Esquinas = cv2.findChessboardCorners(grayROI, (chBrdCols,chBrdRows), None)\n",
    "\n",
    "             if retval:\n",
    "\n",
    "                 #Regresar a coordenadas globales\n",
    "                 Esquinas[:,:,0] += xmin\n",
    "                 Esquinas[:,:,1] += ymin\n",
    "\n",
    "         else:\n",
    "\n",
    "             retval, Esquinas = cv2.findChessboardCorners(img, (chBrdCols,chBrdRows), None)            \n",
    "\n",
    "         if retval == True:\n",
    "            Esquinas = Esquinas[:,0,:]\n",
    "            for i in range(nCorners):\n",
    "               cv2.circle(img, np.int32(Esquinas[i,:]), 5, (0, 100, 255), 2)\n",
    "\n",
    "            if retval == True: #Si se encontraron las esquinas...\n",
    "\n",
    "               R1, T1 = recoverPose(iK, P3, Esquinas.T)\n",
    "\n",
    "               print (\"R1_%03d = \\n\"%cont, R1,\"\\n\")\n",
    "               print (\"T1_%03d = \"%cont, T1.T,\"\\n\")\n",
    "               print (\"||T1||\",lin.norm(T1),\"\\n\\n\")\n",
    "\n",
    "               ###################################################\n",
    "               # CALCULO DE VELOCIDAD ROTACIONAL Y TRASLACIONAL\n",
    "               ###################################################\n",
    "                \n",
    "               # Estimamos la velocidad de rotación de la cámara omega\n",
    "\n",
    "               if cont > 0:\n",
    "\n",
    "                   #Rotación relativa\n",
    "                   Rrel = R1 @ R0.T\n",
    "\n",
    "                   #Eje + ángulo\n",
    "                   w_axis, theta = logSO3(Rrel)\n",
    "\n",
    "                   #Velocidad angular\n",
    "                   omega = (theta/dt) * w_axis.reshape(3,1)\n",
    "\n",
    "                   #Velocidad lineal\n",
    "                   v = (T1-T0)/dt\n",
    "                   \n",
    "                   #Filtro temporal\n",
    "                   omegaFilt = alpha*omega + (1-alpha)*omegaFilt\n",
    "                   vFilt = alpha*v + (1-alpha)*vFilt\n",
    "                    \n",
    "               # Construimos la matriz xi que corresponde a la derivada de G (G ∈ SE(3)).\n",
    "            \n",
    "                   #Matriz skew(omega)\n",
    "                   Omega = skew(omegaFilt.flatten())\n",
    "            \n",
    "                   #Construir xi\n",
    "                   xi = np.zeros((4,4))\n",
    "                   xi[:3,:3] = Omega\n",
    "                   xi[:3,3] = vFilt.flatten()\n",
    "                \n",
    "                   #Construir pose homogénea actual\n",
    "                   G1 = np.eye(4)\n",
    "                   G1[:3,:3] = R1\n",
    "                   G1[:3,3] = T1.flatten()\n",
    "                \n",
    "               # Estimamos donde podrían estar las equinas del tablero en la siguiente imagen.\n",
    "                   \n",
    "                   #Aproximación de primer orden\n",
    "                   Gnext = (np.eye(4) + xi * dt) @ G1\n",
    "                   Rnext = Gnext[:3,:3]\n",
    "                   Tnext = Gnext[:3,3].reshape(3,1)\n",
    "\n",
    "                   #Transformación 3D predicha\n",
    "                   Pnext3D = np.vstack([Rnext @ P3[:3,:] + Tnext, np.ones(nCorners)])\n",
    "\n",
    "                   #Proyección al plano imagen\n",
    "                   Pimg = K @ Pnext3D[:3,:]\n",
    "\n",
    "                   #Normalización homogénea\n",
    "                   normPH(Pimg)\n",
    "\n",
    "                   #Coordenadas 2D predichas\n",
    "                   Pred2D = Pimg[:2,:]\n",
    "                   \n",
    "               # Proyectamos los puntos estimados en el plano de la imagen\n",
    "            \n",
    "                   for i in range(nCorners):\n",
    "\n",
    "                       #Posición actual\n",
    "                       p_actual = tuple(np.int32(Esquinas[i]))\n",
    "                           \n",
    "                       #Posición predicha\n",
    "                       p_pred = tuple(np.int32(Pred2D[:,i]))\n",
    "                           \n",
    "                       #Flecha velocidad\n",
    "                       cv2.arrowedLine(img, p_actual, p_pred, (255, 0, 200), 3)\n",
    "               \n",
    "               # Graficamos la región donde esperamos se encuentre el tablero de ajedrez\n",
    "                \n",
    "                   #Rectángulo de esquinas internas\n",
    "                   A = Esquinas[0]\n",
    "                   B = Esquinas[chBrdCols-1]\n",
    "                   C = Esquinas[-1]\n",
    "                   D = Esquinas[(chBrdRows-1)*chBrdCols]\n",
    "\n",
    "                   ROI_actual = np.array([A, B, C, D],dtype=np.int32)\n",
    "\n",
    "                   cv2.polylines(img, [ROI_actual], True, (100,255,255), 2)\n",
    "                \n",
    "                   #Rectángulo predicho\n",
    "                   A2 = Pred2D[:,0]\n",
    "                   B2 = Pred2D[:,chBrdCols - 1]\n",
    "                   C2 = Pred2D[:,-1]\n",
    "                   D2 = Pred2D[:,(chBrdRows-1)* chBrdCols]\n",
    "\n",
    "                   ROI_pred = np.array([A2, B2, C2, D2],dtype=np.int32)\n",
    "\n",
    "                   #Centro del cuadrilátero\n",
    "                   center = np.mean(ROI_pred, axis=0)\n",
    "\n",
    "                   #Escalado respecto al centro\n",
    "                   scaleFactor = 1.5\n",
    "                   ROI_pred_scaled = center + scaleFactor*(ROI_pred-center)\n",
    "                   ROI_pred_scaled = ROI_pred_scaled.astype(np.int32)                \n",
    "\n",
    "                   cv2.polylines(img, [ROI_pred_scaled], True, (100,255,0), 2)\n",
    "                \n",
    "                \n",
    "               #Dibujar ejes\n",
    "               drawAxes(img, K, R1, T1, 0.1)\n",
    "\n",
    "            ####################################################\n",
    "            # Actualizar Rotación, Traslación y Conteo de Frames\n",
    "            ####################################################\n",
    "                  \n",
    "            R0 = R1\n",
    "            T0 = T1\n",
    "            cont += 1\n",
    "            \n",
    "         #################################\n",
    "         # Mostrar la ventana \"chessBoard\"\n",
    "         #################################\n",
    "\n",
    "         cv2.imshow(\"chessBoard\", img)\n",
    "         key = cv2.waitKeyEx(DELAY) & 0x000000FF\n",
    "         if key == 27:\n",
    "            break\n",
    "         elif chr(key) == 'a' and FPS > 1:\n",
    "            FPS -= 1\n",
    "            changeFPS = True\n",
    "         elif chr(key) == 'd':\n",
    "            FPS += 1\n",
    "            changeFPS = True\n",
    "         elif chr(key) == 'q':\n",
    "            if FPS > 10:\n",
    "                  FPS -= 10\n",
    "            else:\n",
    "                  FPS = 1\n",
    "            changeFPS = True\n",
    "         elif chr(key) == 'e':\n",
    "            FPS += 10\n",
    "            changeFPS = True\n",
    "\n",
    "         if changeFPS == True:\n",
    "            print (\"FPS = \", FPS)\n",
    "            DELAY=1000//FPS\n",
    "            dt =1./FPS\n",
    "            changeFPS = False\n",
    "      else:\n",
    "         break   \n",
    "            \n",
    "   #################################\n",
    "   # Cerrar ventana\n",
    "   #################################\n",
    "\n",
    "   camera.release()\n",
    "   cv2.destroyAllWindows()\n",
    "\n",
    "#####################\n",
    "# Fin del Programa :)\n",
    "#####################"
   ]
  },
